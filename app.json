{
  "expo": {
    "name": "JEMP",
    "slug": "jemp",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "jemp",
    "userInterfaceStyle": "automatic",
    "locales": {
      "en": "./languages/en.json",
      "de": "./languages/de.json"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "studio.northbyte.jemp",
      "infoPlist": {
        "NSUserTrackingUsageDescription": "We use tracking to measure marketing performance and improve the app experience.",
        "NSPhotoLibraryUsageDescription": "JEMP needs access to your photo library to let you select and attach photos or videos to support tickets and other features.",
        "NSCameraUsageDescription": "JEMP needs access to your camera to let you take photos or videos to attach to support tickets and other features.",
        "ITSAppUsesNonExemptEncryption": false,
        "CFBundleAllowMixedLocalizations": true
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#000000",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "studio.northbyte.jemp",
      "permissions": [],
      "googleServicesFile": "./google-services.json"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "./plugins/withAndroidManifestFixes",
      "expo-router",
      "expo-font",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.855255853074-c396ffah7fudi5coiairklfpe09984k1"
        }
      ],
      "react-native-appsflyer",
      [
        "expo-image-picker",
        {
          "photosPermission": "JEMP benötigt Zugriff auf deine Fotos, um Medien hochzuladen.",
          "cameraPermission": "JEMP benötigt Zugriff auf deine Kamera, um Medien aufzunehmen."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": false,
          "enableBackgroundPlayback": false,
          "enableBackgroundRecording": false
        }
      ],
      [
        "expo-navigation-bar",
        {
          "enforceContrast": false,
          "style": "light"
        }
      ],
      "expo-image",
      "expo-localization",
      "expo-secure-store",
      "expo-sharing",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 150,
          "resizeMode": "contain",
          "backgroundColor": "#0a0a0a",
          "dark": {
            "image": "./assets/images/splash-icon.png",
            "backgroundColor": "#0a0a0a"
          }
        }
      ],
      [
        "expo-status-bar",
        {
          "hidden": false,
          "style": "light"
        }
      ],
      "expo-tracking-transparency",
      "expo-video",
      "expo-web-browser",
      "expo-asset",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/notification-icon.png",
          "color": "#3D9ECB",
          "enableVibration": true,
          "iosDisplayInForeground": true
        }
      ],
      [
        "expo-build-properties",
        {
          "ios": {
            "useFrameworks": "static"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a32d6215-cd4b-4f00-81c0-aa351311fa64"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a32d6215-cd4b-4f00-81c0-aa351311fa64"
    }
  }
}