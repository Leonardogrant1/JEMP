{
  "expo": {
    "name": "JEMP",
    "slug": "jemp",
    "version": "1.0.3",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "jemp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/splash-icon-contain.png",
      "resizeMode": "contain"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "studio.northbyte.jemp",
      "infoPlist": {
        "NSUserTrackingUsageDescription": "We use tracking to measure marketing performance and improve the app experience.",
        "NSPhotoLibraryUsageDescription": "JEMP needs access to your photo library to let you select and attach photos or videos to support tickets and other features.",
        "NSCameraUsageDescription": "JEMP needs access to your camera to let you take photos or videos to attach to support tickets and other features.",
        "ITSAppUsesNonExemptEncryption": false
      },
      "locales": {
        "en": "./languages/en.json",
        "de": "./languages/de.json"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "studio.northbyte.jemp",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-apple-authentication",
      [
        "@react-native-google-signin/google-signin",
        {
          "iosUrlScheme": "com.googleusercontent.apps.855255853074-c396ffah7fudi5coiairklfpe09984k1"
        }
      ],
      "react-native-appsflyer",
      [
        "expo-image-picker",
        {
          "photosPermission": "JEMP benötigt Zugriff auf deine Fotos, um Medien hochzuladen.",
          "cameraPermission": "JEMP benötigt Zugriff auf deine Kamera, um Medien aufzunehmen."
        }
      ],
      [
        "expo-audio",
        {
          "microphonePermission": false,
          "enableBackgroundPlayback": false,
          "enableBackgroundRecording": false
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "a32d6215-cd4b-4f00-81c0-aa351311fa64"
      }
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/a32d6215-cd4b-4f00-81c0-aa351311fa64"
    }
  }
}