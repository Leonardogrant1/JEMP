{
    "ts-node": {
        "files": true
    },
    "compilerOptions": {
        "jsx": "react-jsx",
        "lib": [
            "ES2022",
            "DOM"
        ],
        "target": "es2018",
        "module": "commonjs",
        "baseUrl": ".",
        "outDir": "./dist",
        "esModuleInterop": true,
        "strict": true,
        "skipLibCheck": true
    },
    "include": [
        "src/**/*.ts"
    ],
    "exclude": [
        "node_modules",
        "dist"
    ]
}