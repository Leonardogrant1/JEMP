{
    "name": "jemp-api",
    "version": "1.0.0",
    "description": "JEMP API server — starts Temporal workflows",
    "main": "dist/index.js",
    "scripts": {
        "start": "NODE_ENV=production node dist/index.js",
        "build": "esbuild src/index.ts --bundle --platform=node --target=node22 --outfile=dist/index.js --external:@temporalio/worker --sourcemap",
        "dev": "nodemon --watch src --exec ts-node --project ./tsconfig.json src/index.ts",
        "deploy:dev": "cd ../../ && bash ./deploy-fly.sh dev jemp-api",
        "deploy:prod": "cd ../../ && bash ./deploy-fly.sh prod jemp-api"
    },
    "dependencies": {
        "@supabase/supabase-js": "^2.44.4",
        "@temporalio/client": "^1.11.6",
        "dotenv": "^16.4.5",
        "express": "^4.19.2",
        "helmet": "^8.1.0"
    },
    "devDependencies": {
        "@types/express": "^4.17.21",
        "@types/node": "^22.5.4",
        "esbuild": "^0.24.0",
        "nodemon": "^3.1.7",
        "ts-node": "^10.9.2",
        "typescript": "^5.5.4"
    },
    "allowScripts": {
        "esbuild@0.24.2": true,
        "protobufjs@7.5.8": true,
        "protobufjs@7.6.4": true,
        "fsevents@2.3.3": true
    }
}
